<Project Sdk="Microsoft.Build.Traversal">
  <ItemGroup>
    <!-- Tests and Helpers -->
    <ProjectReference Include="*/*.csproj" />

    <!-- Tests are broken as it hasn't been run on main in a while. Relies on older System.CommandLine API's that are no longer public -->
    <ProjectReference Remove="dotnet-stack/DotnetStack.UnitTests.csproj" />

    <!-- Standalone tools -->
    <ProjectReference Remove="DacCompareNativeTypes/DacCompareNativeTypes.csproj" />
    <ProjectReference Remove="benchmarks/benchmarks.csproj" />
    <ProjectReference Remove="EventPipeStress/**/*.csproj" />

    <!-- Unused -->
    <ProjectReference Remove="Grape/Grape.csproj" />
  </ItemGroup>

  <!--
    Install test runtimes and build debuggees using the test SDK.
    Debuggees are built separately because they may target TFMs newer
    than what the global.json (product) SDK supports.
  -->

  <PropertyGroup>
    <!-- Detect whether this is a cross-architecture build (host != target) -->
    <HostArch>$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture.ToString().ToLowerInvariant)</HostArch>
    <IsCrossArchBuild Condition="'$(HostArch)' != '$(TargetArch)'">true</IsCrossArchBuild>
    <!-- When cross-building, use a separate host-arch SDK dir for building debuggees -->
    <DebuggeeBuildDotNetDir Condition="'$(IsCrossArchBuild)' == 'true'">$([MSBuild]::NormalizeDirectory('$(ArtifactsDir)', 'dotnet-build'))</DebuggeeBuildDotNetDir>
    <DebuggeeBuildDotNetDir Condition="'$(IsCrossArchBuild)' != 'true'">$(ArtifactsDotnetTestDir)</DebuggeeBuildDotNetDir>
    <DebuggeeBuildDotNetPath>$([MSBuild]::NormalizePath('$(DebuggeeBuildDotNetDir)', 'dotnet'))</DebuggeeBuildDotNetPath>
    <TestDotNetPath>$([MSBuild]::NormalizePath('$(ArtifactsDotnetTestDir)', 'dotnet'))</TestDotNetPath>
  </PropertyGroup>

  <Target Name="InstallTestRuntimes"
          AfterTargets="Build"
          Condition="'$(SkipTests)' != 'true'">
    <MSBuild Projects="$(RepositoryEngineeringDir)InstallRuntimes.proj"
             Targets="InstallTestRuntimes"
             Properties="TargetArch=$(TargetArch);TargetOS=$(TargetOS);TestArchitectures=$(TargetArch);PrivateBuildTesting=$(PrivateBuildTesting);LiveRuntimeDir=$(LiveRuntimeDir);HostArch=$(HostArch)" />
  </Target>

  <Target Name="BuildDebuggees"
          AfterTargets="Build"
          DependsOnTargets="InstallTestRuntimes"
          Condition="'$(SkipTests)' != 'true'">
    <!-- Remove stale SDKs from the build dotnet dir so the repo root global.json
         (rollForward:major) resolves to the correct test SDK.  InstallTestRuntimes
         only installs $(MicrosoftNETSdkVersion); older SDKs are leftovers. -->
    <ItemGroup>
      <_StaleTestSdks Include="$([System.IO.Directory]::GetDirectories('$(DebuggeeBuildDotNetDir)sdk'))" />
      <_StaleTestSdks Remove="$([MSBuild]::NormalizePath('$(DebuggeeBuildDotNetDir)', 'sdk', '$(MicrosoftNETSdkVersion)'))" />
    </ItemGroup>
    <RemoveDir Directories="@(_StaleTestSdks)" />
    <!-- Clean up any generated global.json from prior runs that would shadow the repo root's -->
    <Delete Files="$(ArtifactsDir)global.json" Condition="Exists('$(ArtifactsDir)global.json')" />
    <PropertyGroup>
      <_BuildSdkVersionDir>$([MSBuild]::NormalizePath('$(DebuggeeBuildDotNetDir)', 'sdk', '$(MicrosoftNETSdkVersion)'))</_BuildSdkVersionDir>
    </PropertyGroup>
    <ItemGroup>
      <DebuggeeBuildEnv Include="DOTNET_ROOT=$(DebuggeeBuildDotNetDir.TrimEnd('\/'))" />
      <DebuggeeBuildEnv Include="DOTNET_MSBUILD_SDK_RESOLVER_CLI_DIR=$(DebuggeeBuildDotNetDir.TrimEnd('\/'))" />
      <DebuggeeBuildEnv Include="DOTNET_HOST_PATH=$(DebuggeeBuildDotNetPath)" />
      <DebuggeeBuildEnv Include="DOTNET_INSTALL_DIR=$(DebuggeeBuildDotNetDir.TrimEnd('\/'))" />
      <!-- Override inherited MSBuild env vars that point to the build SDK -->
      <DebuggeeBuildEnv Include="MSBuildSDKsPath=$(_BuildSdkVersionDir)$([System.IO.Path]::DirectorySeparatorChar)Sdks" />
      <DebuggeeBuildEnv Include="MSBuildExtensionsPath=$(_BuildSdkVersionDir)" />
    </ItemGroup>
    <Exec Command="$(DebuggeeBuildDotNetPath) build $(MSBuildThisFileDirectory)Debuggees.proj -c $(Configuration) -bl:$(ArtifactsLogDir)Debuggees.binlog /p:TargetOS=$(TargetOS) /p:TargetArch=$(TargetArch) /p:RepoRoot=$(RepoRoot)"
          WorkingDirectory="$(DebuggeeBuildDotNetDir)"
          EnvironmentVariables="@(DebuggeeBuildEnv)" />
  </Target>
</Project>
